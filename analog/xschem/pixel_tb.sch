C {devices/code.sym} -420 -210 0 0 {name=TT_MODELS
only_toplevel=true
format="tcleval( @value )"
value="
** opencircuitdesign pdks install
.lib $::SKYWATER_MODELS/sky130.lib.spice tt
"
spice_ignore=false}
C {devices/launcher.sym} -170 -300 2 1 {name=h1
descr="Annotate OP" 
tclcommand="set show_hidden_texts 1; xschem annotate_op"
}
C {code_shown.sym} -1280 -550 0 0 {name=NGSPICE
only_toplevel=true
value="

.param xvdd = 1.8
.param xipd = 1e-9
.param xPrBp = 10n
.param xPrSFBp = 1n
.param xRefrBp = 4u
.param xDiffBn = 10n
.param xOnBn = 100n
.param xOffBn = 1n

.param xtr = 0.1n
.param xtperRead = 3u
.param xtdReadON = 100n
.param xtlenReadON = 950n
.param xtlenReadOFF = 950n
.param xtlenRstPhase = 950n
.param xtdReadOFF = 'xtdReadON+xtlenReadON+10n'
.param xtdRstPhase = 'xtdReadOFF+xtlenReadOFF+10n'
.param xtdRowSel = 50n
.param xtperRowSel = '2*xtperRead'

.param CloadPD = 30f
.param xCloadReadLine = 300f
.param xCloadRowReadON = 300f
.param xCloadRowReadOFF = 300f
.param xCloadPixRst = 300f

*Small Iphoto testing
Iphoto1 vpd gnd pulse(50n 100n 12u 5n 5n 5.99u 30u) 
Iphoto2 vpd gnd pulse(50n 25n 24u 5n 5n 5.99u 30u)

.option gmin=1e-18 abstol=1e-15 vntol=1e-9 reltol=1e-6 chgtol=1e-16 trtol=6

.control
	
	save all
	op
	tran 0.1n 39u 
        write pixel_tb.raw
.endc
"}
